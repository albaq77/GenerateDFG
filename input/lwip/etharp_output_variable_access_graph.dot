strict digraph etharp_output {
  1 [label="%struct.ip4_addr** %10", size=4, color=blue, shape=record];
  2 [label="%struct.ip4_addr** %7", size=4, color=blue, shape=record];
  3 [label="%struct.netif** %5", size=408, color=blue, shape=record];
  4 [label="%struct.pbuf** %6", size=24, color=blue, shape=record];
  4 -> 3 [label="weight=1", weight="1"];
  2 -> 3 [label="weight=1", weight="1"];
  4 -> 2 [label="weight=1", weight="1"];
  1 -> 3 [label="weight=1", weight="1"];
  4 -> 1 [label="weight=1", weight="1"];
  2 -> 1 [label="weight=1", weight="1"];
}