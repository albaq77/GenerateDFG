strict digraph mld6_report_groups {
  1 [label="%struct.mld_group*-%struct.mld_group** %3", size=40, color=blue, shape=record];
  2 [label="%struct.mld_group*-%struct.mld_group** %struct.mld_group* %3, i32 0, i32 0", size=40, color=blue, shape=record];
  3 [label="%struct.netif*-%struct.netif** %2", size=408, color=blue, shape=record];
  3 -> 1 [label="weight=1", weight="1"];
  3 -> 2 [label="weight=1", weight="1"];
  2 -> 1 [label="weight=1", weight="1"];
}