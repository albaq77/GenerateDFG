strict digraph igmp_report_groups {
  1 [label="%struct.igmp_group*-%struct.igmp_group** %3", size=24, color=blue, shape=record];
  2 [label="%struct.igmp_group*-%struct.igmp_group** %struct.igmp_group* %3, i32 0, i32 0", size=24, color=blue, shape=record];
  3 [label="%struct.netif*-%struct.netif** %2", size=408, color=blue, shape=record];
  1 -> 3 [label="weight=1", weight="1"];
  3 -> 2 [label="weight=1", weight="1"];
  1 -> 2 [label="weight=1", weight="1"];
}