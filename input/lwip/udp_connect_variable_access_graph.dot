strict digraph udp_connect {
  1 [label="%struct.ip_addr** %6", size=24, color=blue, shape=record];
  2 [label="%struct.udp_pcb** %5", size=104, color=blue, shape=record];
  3 [label="i16* %7", size=2, color=blue, shape=record];
  4 [label="i8* %4", size=1, color=blue, shape=record];
  5 [label="i8* %struct.ip_addr* %6, i32 0, i32 1", size=1, color=blue, shape=record];
  1 -> 2 [label="weight=1", weight="1"];
  3 -> 2 [label="weight=1", weight="1"];
  1 -> 3 [label="weight=1", weight="1"];
  4 -> 2 [label="weight=1", weight="1"];
  1 -> 4 [label="weight=1", weight="1"];
  3 -> 4 [label="weight=1", weight="1"];
  5 -> 2 [label="weight=1", weight="1"];
  1 -> 5 [label="weight=1", weight="1"];
  3 -> 5 [label="weight=1", weight="1"];
  5 -> 4 [label="weight=1", weight="1"];
}