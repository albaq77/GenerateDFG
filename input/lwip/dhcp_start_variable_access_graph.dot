strict digraph dhcp_start {
  1 [label="%struct.netif*-%struct.netif** %3", size=408, color=blue, shape=record];
  2 [label="%struct.netif*-i16* %struct.netif* %3, i32 0, i32 16", size=2, color=blue, shape=record];
  3 [label="%struct.netif*-i8* %struct.netif* %3, i32 0, i32 20", size=1, color=blue, shape=record];
  4 [label="i8-i8* %2", size=1, color=blue, shape=record];
  1 -> 3 [label="weight=1", weight="1"];
  1 -> 4 [label="weight=1", weight="1"];
  4 -> 3 [label="weight=1", weight="1"];
  2 -> 1 [label="weight=1", weight="1"];
  2 -> 3 [label="weight=1", weight="1"];
  2 -> 4 [label="weight=1", weight="1"];
}