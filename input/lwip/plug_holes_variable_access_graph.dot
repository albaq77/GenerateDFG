strict digraph plug_holes {
  1 [label="%struct.mem*-%struct.mem** %2", size=6, color=blue, shape=record];
  2 [label="%struct.mem*-%struct.mem** %3", size=6, color=blue, shape=record];
  3 [label="%struct.mem*-i16* %struct.mem* %2, i32 0, i32 0", size=2, color=blue, shape=record];
  4 [label="%struct.mem*-i8* %struct.mem* %2, i32 0, i32 2", size=1, color=blue, shape=record];
  5 [label="%struct.mem*-i8* %struct.mem* %3, i32 0, i32 2", size=1, color=blue, shape=record];
  1 -> 4 [label="weight=1", weight="1"];
  1 -> 2 [label="weight=1", weight="1"];
  2 -> 4 [label="weight=1", weight="1"];
  5 -> 1 [label="weight=1", weight="1"];
  5 -> 4 [label="weight=1", weight="1"];
  5 -> 2 [label="weight=1", weight="1"];
  3 -> 1 [label="weight=1", weight="1"];
  3 -> 4 [label="weight=1", weight="1"];
  3 -> 2 [label="weight=1", weight="1"];
  3 -> 5 [label="weight=1", weight="1"];
}