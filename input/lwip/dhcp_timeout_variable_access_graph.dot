strict digraph dhcp_timeout {
  1 [label="%struct.dhcp*-%struct.dhcp** %3", size=104, color=blue, shape=record];
  2 [label="%struct.dhcp*-i8* %struct.dhcp* %3, i32 0, i32 2", size=1, color=blue, shape=record];
  3 [label="%struct.netif*-%struct.netif** %2", size=408, color=blue, shape=record];
  1 -> 3 [label="weight=1", weight="1"];
  3 -> 2 [label="weight=1", weight="1"];
  1 -> 2 [label="weight=1", weight="1"];
}