strict digraph tcpip_input {
  1 [label="%struct.netif** %5", size=408, color=blue, shape=record];
  2 [label="%struct.pbuf** %4", size=24, color=blue, shape=record];
  3 [label="i8* %3", size=1, color=blue, shape=record];
  4 [label="i8* %struct.netif* %5, i32 0, i32 20", size=1, color=blue, shape=record];
  2 -> 1 [label="weight=1", weight="1"];
  4 -> 2 [label="weight=1", weight="1"];
  4 -> 1 [label="weight=1", weight="1"];
  3 -> 2 [label="weight=1", weight="1"];
  3 -> 1 [label="weight=1", weight="1"];
  4 -> 3 [label="weight=1", weight="1"];
}