strict digraph dhcp_option_trailer {
  1 [label="%struct.pbuf** %6", size=24, color=blue, shape=record];
  2 [label="i16* %4", size=2, color=blue, shape=record];
  3 [label="i8* i8* %5, i64 %4", size=1, color=blue, shape=record];
  4 [label="i8** %5", size=1, color=blue, shape=record];
  4 -> 2 [label="weight=1", weight="1"];
  1 -> 2 [label="weight=1", weight="1"];
  1 -> 4 [label="weight=1", weight="1"];
  3 -> 2 [label="weight=1", weight="1"];
  3 -> 4 [label="weight=1", weight="1"];
  1 -> 3 [label="weight=1", weight="1"];
}