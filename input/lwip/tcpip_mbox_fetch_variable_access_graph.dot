strict digraph tcpip_mbox_fetch {
  1 [label="%struct.sys_mbox**-%struct.sys_mbox*** %3", size=1064, color=blue, shape=record];
  2 [label="i32-i32* %5", size=4, color=blue, shape=record];
  3 [label="i8**-i8*** %4", size=1, color=blue, shape=record];
  3 -> 1 [label="weight=1", weight="1"];
  2 -> 1 [label="weight=1", weight="1"];
  2 -> 3 [label="weight=1", weight="1"];
}