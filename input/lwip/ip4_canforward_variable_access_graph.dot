strict digraph ip4_canforward {
  1 [label="%struct.pbuf** %3", size=24, color=blue, shape=record];
  2 [label="i32* %2", size=4, color=blue, shape=record];
  3 [label="i32* %4", size=4, color=blue, shape=record];
  4 [label="i8* %struct.pbuf* %3, i32 0, i32 5", size=1, color=blue, shape=record];
  3 -> 1 [label="weight=1", weight="1"];
  1 -> 4 [label="weight=1", weight="1"];
  3 -> 4 [label="weight=1", weight="1"];
  1 -> 2 [label="weight=1", weight="1"];
  3 -> 2 [label="weight=1", weight="1"];
  2 -> 4 [label="weight=1", weight="1"];
}