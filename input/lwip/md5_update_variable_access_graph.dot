  3 [label="i32-i32* %7", size=4, color=blue, shape=record];
  4 [label="i64-i64* %8", size=8, color=blue, shape=record];
  5 [label="i8*-i8** %5", size=1, color=blue, shape=record];
  5 -> 1 [label="weight=1", weight="1"];
  1 -> 2 [label="weight=1", weight="1"];
  5 -> 2 [label="weight=1", weight="1"];
  1 -> 4 [label="weight=1", weight="1"];
  5 -> 4 [label="weight=1", weight="1"];
  2 -> 4 [label="weight=1", weight="1"];
  1 -> 3 [label="weight=1", weight="1"];
  5 -> 3 [label="weight=1", weight="1"];
  2 -> 3 [label="weight=1", weight="1"];
  4 -> 3 [label="weight=1", weight="1"];
}