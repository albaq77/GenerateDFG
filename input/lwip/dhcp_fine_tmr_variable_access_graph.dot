  3 [label="%struct.netif*-%struct.netif** %1", size=408, color=blue, shape=record];
  1 -> 3 [label="weight=1", weight="1"];
  3 -> 2 [label="weight=1", weight="1"];
  1 -> 2 [label="weight=1", weight="1"];
}