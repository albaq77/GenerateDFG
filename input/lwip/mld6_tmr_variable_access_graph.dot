  4 [label="%struct.netif*-%struct.netif** %1", size=408, color=blue, shape=record];
  4 -> 1 [label="weight=1", weight="1"];
  3 -> 4 [label="weight=1", weight="1"];
  3 -> 1 [label="weight=1", weight="1"];
  4 -> 2 [label="weight=1", weight="1"];
  2 -> 1 [label="weight=1", weight="1"];
  3 -> 2 [label="weight=1", weight="1"];
}