strict digraph dhcp_set_state {
  1 [label="%struct.dhcp** %3", size=104, color=blue, shape=record];
  2 [label="i16* %struct.dhcp* %3, i32 0, i32 5", size=2, color=blue, shape=record];
  3 [label="i8* %4", size=1, color=blue, shape=record];
  4 [label="i8* %struct.dhcp* %3, i32 0, i32 2", size=1, color=blue, shape=record];
  5 [label="i8* %struct.dhcp* %3, i32 0, i32 3", size=1, color=blue, shape=record];
  1 -> 3 [label="weight=1", weight="1"];
  4 -> 1 [label="weight=1", weight="1"];
  4 -> 3 [label="weight=1", weight="1"];
  1 -> 5 [label="weight=1", weight="1"];
  5 -> 3 [label="weight=1", weight="1"];
  4 -> 5 [label="weight=1", weight="1"];
  1 -> 2 [label="weight=1", weight="1"];
  2 -> 3 [label="weight=1", weight="1"];
  4 -> 2 [label="weight=1", weight="1"];
  5 -> 2 [label="weight=1", weight="1"];
}