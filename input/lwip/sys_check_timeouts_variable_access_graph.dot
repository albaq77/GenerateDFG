strict digraph sys_check_timeouts {
  1 [label="%struct.sys_timeo*-%struct.sys_timeo** %2", size=32, color=blue, shape=record];
  2 [label="%struct.sys_timeo*-i32* %struct.sys_timeo* %2, i32 0, i32 1", size=4, color=blue, shape=record];
  3 [label="i32-i32* %1", size=4, color=blue, shape=record];
  1 -> 3 [label="weight=1", weight="1"];
  3 -> 2 [label="weight=1", weight="1"];
  1 -> 2 [label="weight=1", weight="1"];
}