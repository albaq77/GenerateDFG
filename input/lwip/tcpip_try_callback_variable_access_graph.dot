strict digraph tcpip_try_callback {
  1 [label="%4-void (i8*)** %4", size=0, color=blue, shape=record];
  2 [label="%struct.tcpip_msg*-%struct.tcpip_msg** %6", size=32, color=blue, shape=record];
  3 [label="i8*-i8** %5", size=1, color=blue, shape=record];
  4 [label="i8-i8* %3", size=1, color=blue, shape=record];
  1 -> 3 [label="weight=1", weight="1"];
  1 -> 2 [label="weight=1", weight="1"];
  3 -> 2 [label="weight=1", weight="1"];
  1 -> 4 [label="weight=1", weight="1"];
  3 -> 4 [label="weight=1", weight="1"];
  2 -> 4 [label="weight=1", weight="1"];
}