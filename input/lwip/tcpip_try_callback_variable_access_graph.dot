strict digraph tcpip_try_callback {
  1 [label="%struct.tcpip_msg** %6", size=32, color=blue, shape=record];
  2 [label="i8* %3", size=1, color=blue, shape=record];
  3 [label="i8** %5", size=1, color=blue, shape=record];
  4 [label="void (i8*)** %4", size=0, color=blue, shape=record];
  4 -> 3 [label="weight=1", weight="1"];
  4 -> 1 [label="weight=1", weight="1"];
  1 -> 3 [label="weight=1", weight="1"];
  4 -> 2 [label="weight=1", weight="1"];
  2 -> 3 [label="weight=1", weight="1"];
  1 -> 2 [label="weight=1", weight="1"];
}